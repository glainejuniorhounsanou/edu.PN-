<html lang="fr">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>EduPN — Plateforme Éducative Nationale</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link href="https://fonts.googleapis.com/css2?family=Nunito:wght@400;600;700;800;900&family=Inter:wght@400;500;600&display=swap" rel="stylesheet">
</head>
<body>
  <div id="root"></div>
  <script type="module" src="/src/main.jsx"></script>
</body>
</html>{
  "name": "edupn",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview"
  },
  "dependencies": {
    "react": "^18.2.0",
    "react-dom": "^18.2.0"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.0.0",
    "vite": "^5.0.0"
  }import { defineConfig } from 'vite'
import react from '@vitejs/plugin-react'

export default defineConfig({
  plugins: [react()],
  base: './',
})
}import React from 'react'
import ReactDOM from 'react-dom/client'
import App from './App.jsx'
import './styles/global.css'

ReactDOM.createRoot(document.getElementById('root')).render(
  <React.StrictMode>
    <App />
  </React.StrictMode>
)*, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

:root {
  --cobalt: #1B3A6B;
  --cobalt-light: #2A5298;
  --cobalt-dark: #0F2347;
  --mint: #2DBE8C;
  --mint-light: #4ECBA0;
  --mint-pale: #E8FAF4;
  --amber: #F6A623;
  --amber-pale: #FFF4DC;
  --slate: #4A5568;
  --slate-light: #718096;
  --slate-pale: #E2E8F0;
  --bg: #F8FAFF;
  --surface: #EEF2FF;
  --white: #FFFFFF;
  --danger: #E53E3E;
  --danger-pale: #FFF5F5;
  --font-display: 'Nunito', sans-serif;
  --font-body: 'Inter', sans-serif;
  --radius: 12px;
  --radius-sm: 8px;
  --shadow: 0 2px 12px rgba(27,58,107,0.08);
  --shadow-md: 0 4px 24px rgba(27,58,107,0.12);
  --transition: all 0.2s ease;
}

html { font-size: 16px; scroll-behavior: smooth; }
body {
  font-family: var(--font-body);
  background: var(--bg);
  color: var(--slate);
  line-height: 1.6;
  -webkit-font-smoothing: antialiased;
}

h1,h2,h3,h4,h5,h6 { font-family: var(--font-display); color: var(--cobalt); line-height: 1.3; font-weight: 700; }
a { text-decoration: none; color: inherit; }
button { cursor: pointer; border: none; outline: none; font-family: var(--font-body); }
input, select, textarea { font-family: var(--font-body); outline: none; }

::-webkit-scrollbar { width: 6px; }
::-webkit-scrollbar-track { background: var(--surface); }
::-webkit-scrollbar-thumb { background: var(--cobalt-light); border-radius: 3px; }

.btn {
  display: inline-flex; align-items: center; gap: 8px;
  padding: 10px 20px; border-radius: var(--radius-sm);
  font-weight: 600; font-size: 0.875rem;
  transition: var(--transition); cursor: pointer;
}
.btn-primary { background: var(--cobalt); color: white; }
.btn-primary:hover { background: var(--cobalt-light); transform: translateY(-1px); box-shadow: var(--shadow-md); }
.btn-mint { background: var(--mint); color: white; }
.btn-mint:hover { background: var(--mint-light); transform: translateY(-1px); }
.btn-ghost { background: transparent; color: var(--cobalt); border: 1.5px solid var(--cobalt); }
.btn-ghost:hover { background: var(--surface); }
.btn-danger { background: var(--danger); color: white; }
.btn-sm { padding: 6px 14px; font-size: 0.8rem; }
.btn-lg { padding: 14px 28px; font-size: 1rem; border-radius: var(--radius); }

.badge {
  display: inline-flex; align-items: center; gap: 4px;
  padding: 3px 10px; border-radius: 100px;
  font-size: 0.75rem; font-weight: 600; font-family: var(--font-display);
}
.badge-mint { background: var(--mint-pale); color: var(--mint); }
.badge-cobalt { background: var(--surface); color: var(--cobalt); }
.badge-amber { background: var(--amber-pale); color: #B7791F; }
.badge-danger { background: var(--danger-pale); color: var(--danger); }

.card {
  background: white; border-radius: var(--radius);
  box-shadow: var(--shadow); padding: 24px;
  transition: var(--transition);
}
.card:hover { box-shadow: var(--shadow-md); }

.table-wrap { overflow-x: auto; border-radius: var(--radius); }
table { width: 100%; border-collapse: collapse; }
thead th {
  background: var(--surface); color: var(--cobalt);
  font-family: var(--font-display); font-weight: 700;
  font-size: 0.8rem; text-transform: uppercase; letter-spacing: 0.05em;
  padding: 12px 16px; text-align: left;
}
tbody td { padding: 14px 16px; border-bottom: 1px solid var(--slate-pale); font-size: 0.9rem; }
tbody tr:last-child td { border-bottom: none; }
tbody tr:hover td { background: var(--bg); }

.input-group { display: flex; flex-direction: column; gap: 6px; }
.input-group label { font-size: 0.85rem; font-weight: 600; color: var(--cobalt); font-family: var(--font-display); }
.input {
  padding: 10px 14px; border: 1.5px solid var(--slate-pale);
  border-radius: var(--radius-sm); font-size: 0.9rem;
  transition: var(--transition); background: white; color: var(--slate);
}
.input:focus { border-color: var(--cobalt); box-shadow: 0 0 0 3px rgba(27,58,107,0.1); }
.input::placeholder { color: var(--slate-light); }

@keyframes fadeIn { from { opacity: 0; transform: translateY(12px); } to { opacity: 1; transform: translateY(0); } }
@keyframes slideIn { from { opacity: 0; transform: translateX(-20px); } to { opacity: 1; transform: translateX(0); } }
.animate-fade { animation: fadeIn 0.35s ease forwards; }
.animate-slide { animation: slideIn 0.3s ease forwards; }

#app-layout { display: flex; min-height: 100vh; }
#sidebar {
  width: 260px; min-height: 100vh;
  background: var(--cobalt-dark);
  display: flex; flex-direction: column;
  position: fixed; top: 0; left: 0; z-index: 100;
  transition: transform 0.3s ease;
}
#main-content { margin-left: 260px; flex: 1; display: flex; flex-direction: column; min-height: 100vh; }
#topbar {
  background: white; height: 64px;
  display: flex; align-items: center; justify-content: space-between;
  padding: 0 24px; box-shadow: 0 1px 0 var(--slate-pale);
  position: sticky; top: 0; z-index: 50;
}
#page-content { padding: 28px 24px; flex: 1; }

@media (max-width: 768px) {
  #sidebar { transform: translateX(-100%); }
  #sidebar.open { transform: translateX(0); }
  #main-content { margin-left: 0; }
  #page-content { padding: 16px; }
