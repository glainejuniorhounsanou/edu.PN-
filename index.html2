export const stats = {
  totalEleves: 45280,
  totalEcoles: 8420,
  totalProfesseurs: 12650,
  tauxScolarisation: 71.4,
}import React, { useState, createContext, useContext } from 'react'
import { users } from './data/db.js'
import PageAccueil from './pages/PageAccueil.jsx'
import PageConnexion from './pages/PageConnexion.jsx'
import PageDashboard from './pages/PageDashboard.jsx'
import PageEcoles from './pages/PageEcoles.jsx'
import PageEleves from './pages/PageEleves.jsx'
import PageProfesseurs from './pages/PageProfesseurs.jsx'
import PageExamens from './pages/PageExamens.jsx'
import PageParents from './pages/PageParents.jsx'
import PageNotes from './pages/PageNotes.jsx'
import PageEmploi from './pages/PageEmploi.jsx'
import Layout from './components/Layout.jsx'

export const AppContext = createContext(null)
export function useApp() { return useContext(AppContext) }

export default function App() {
  const [page, setPage] = useState('accueil')
  const [currentUser, setCurrentUser] = useState(null)
  const [sidebarOpen, setSidebarOpen] = useState(false)
  const [notification, setNotification] = useState(null)

  const navigate = (p) => { setPage(p); setSidebarOpen(false); window.scrollTo(0,0) }

  const login = (email, password) => {
    const u = users.find(u => u.email === email && u.password === password)
    if (u) {
      setCurrentUser(u)
      setNotification({ type:'success', msg:`Bienvenue, ${u.prenom} ${u.nom} !` })
      setTimeout(() => setNotification(null), 3000)
      navigate('dashboard')
      return true
    }
    return false
  }

  const logout = () => { setCurrentUser(null); navigate('accueil') }

  const ctx = { page, navigate, currentUser, login, logout, sidebarOpen, setSidebarOpen, notification, setNotification }

  const renderPage = () => {
    if (!currentUser && !['accueil','connexion'].includes(page)) return <PageConnexion />
    switch(page) {
      case 'accueil':     return <PageAccueil />
      case 'connexion':   return <PageConnexion />
      case 'dashboard':   return <PageDashboard />
      case 'ecoles':      return <PageEcoles />
      case 'eleves':      return <PageEleves />
      case 'professeurs': return <PageProfesseurs />
      case 'examens':     return <PageExamens />
      case 'parents':     return <PageParents />
      case 'notes':       return <PageNotes />
      case 'emploi':      return <PageEmploi />
      default:            return <PageDashboard />
    }
  }

  return (
    <AppContext.Provider value={ctx}>
      {notification && (
        <div style={{
          position:'fixed', top:16, right:16, zIndex:9999,
          background: notification.type==='success' ? '#2DBE8C' : '#E53E3E',
          color:'white', padding:'12px 20px', borderRadius:10,
          fontFamily:'Nunito,sans-serif', fontWeight:700,
          boxShadow:'0 4px 20px rgba(0,0,0,0.2)', animation:'fadeIn 0.3s ease'
        }}>
          {notification.msg}
        </div>
      )}
      {['accueil','connexion'].includes(page) ? renderPage() : <Layout>{renderPage()}</Layout>}
    </AppContext.Provider>
  )
}import React from 'react'
import Sidebar from './Sidebar.jsx'
import Topbar from './Topbar.jsx'

export default function Layout({ children }) {
  return (
    <div id="app-layout">
      <Sidebar />
      <div id="main-content">
        <Topbar />
        <div id="page-content" className="animate-fade">
          {children}
        </div>
      </div>
    </div>
  )
}import React from 'react'
import { useApp } from '../App.jsx'

const navItems = [
  { id:'dashboard', label:'Tableau de bord', icon:'⊞', roles:['admin','parent','eleve','professeur'] },
  { id:'ecoles', label:'Écoles', icon:'🏫', roles:['admin'] },
  { id:'eleves', label:'Élèves', icon:'👨‍🎓', roles:['admin','professeur'] },
  { id:'professeurs', label:'Professeurs', icon:'👨‍🏫', roles:['admin'] },
  { id:'notes', label:'Notes & Bulletins', icon:'📊', roles:['admin','professeur','eleve','parent'] },
  { id:'emploi', label:'Emploi du temps', icon:'🗓️', roles:['admin','professeur','eleve','parent'] },
  { id:'examens', label:'Examens & Concours', icon:'📝', roles:['admin','eleve','parent','professeur'] },
  { id:'parents', label:'Espace Parents', icon:'👨‍👩‍👧', roles:['admin','parent'] },
]

export default function Sidebar() {
  const { page, navigate, currentUser, logout, sidebarOpen } = useApp()
  const role = currentUser?.role || 'eleve'
  const filtered = navItems.filter(i => i.roles.includes(role))
  const roleColor = { admin:'#F6A623', parent:'#2DBE8C', eleve:'#667EEA', professeur:'#ED8936' }[role] || '#2DBE8C'

  return (
    <nav id="sidebar" className={sidebarOpen ? 'open' : ''} style={{overflowY:'auto'}}>
      {/* Logo */}
      <div style={{padding:'24px 20px 16px', borderBottom:'1px solid rgba(255,255,255,0.1)'}}>
        <div style={{display:'flex', alignItems:'center', gap:10}}>
          <div style={{width:40,height:40,borderRadius:10,background:'linear-gradient(135deg,#2DBE8C,#1B8C65)',display:'flex',alignItems:'center',justifyContent:'center',fontFamily:'Nunito,sans-serif',fontWeight:900,color:'white',fontSize:'1.2rem'}}>E</div>
          <div>
            <div style={{fontFamily:'Nunito,sans-serif',fontWeight:900,color:'white',fontSize:'1.2rem',lineHeight:1}}>EduPN</div>
            <div style={{color:'rgba(255,255,255,0.5)',fontSize:'0.7rem'}}>Plateforme Éducative</div>
          </div>
        </div>
      </div>

      {/* User badge */}
      <div style={{padding:'14px 20px', borderBottom:'1px solid rgba(255,255,255,0.08)'}}>
        <div style={{background:'rgba(255,255,255,0.07)',borderRadius:10,padding:'10px 14px',display:'flex',alignItems:'center',gap:10}}>
          <div style={{width:34,height:34,borderRadius:'50%',background:roleColor,display:'flex',alignItems:'center',justifyContent:'center',fontSize:'0.9rem',fontWeight:800,color:'white',fontFamily:'Nunito,sans-serif',flexShrink:0}}>
            {currentUser ? (currentUser.prenom[0]+currentUser.nom[0]) : 'U'}
          </div>
          <div style={{overflow:'hidden'}}>
            <div style={{color:'white',fontFamily:'Nunito,sans-serif',fontWeight:700,fontSize:'0.85rem',whiteSpace:'nowrap',overflow:'hidden',textOverflow:'ellipsis'}}>
              {currentUser ? `${currentUser.prenom} ${currentUser.nom}` : 'Utilisateur'}
            </div>
            <div style={{color:roleColor,fontSize:'0.7rem',fontFamily:'Nunito,sans-serif',fontWeight:700,textTransform:'uppercase',letterSpacing:'0.05em'}}>{role}</div>
          </div>
        </div>
      </div>

      {/* Nav items */}
      <div style={{flex:1, padding:'12px'}}>
        <div style={{color:'rgba(255,255,255,0.35)',fontSize:'0.65rem',fontFamily:'Nunito,sans-serif',fontWeight:700,textTransform:'uppercase',letterSpacing:'0.1em',padding:'8px 8px 4px'}}>Navigation</div>
        {filtered.map(item => {
          const active = page === item.id
          return (
            <button key={item.id} onClick={() => navigate(item.id)} style={{
              width:'100%',display:'flex',alignItems:'center',gap:10,
              padding:'10px 12px',borderRadius:10,marginBottom:2,
              background: active ? roleColor : 'transparent',
              color: active ? 'white' : 'rgba(255,255,255,0.7)',
              fontFamily:'Nunito,sans-serif',fontWeight:active?700:500,
              fontSize:'0.9rem',transition:'all 0.2s',border:'none',cursor:'pointer',textAlign:'left'
            }}
            onMouseEnter={e => { if(!active) e.currentTarget.style.background='rgba(255,255,255,0.08)' }}
            onMouseLeave={e => { if(!active) e.currentTarget.style.background='transparent' }}>
              <span style={{fontSize:'1.1rem'}}>{item.icon}</span>
              {item.label}
            </button>
          )
        })}
      </div>

      {/* Logout */}
      <div style={{padding:'12px', borderTop:'1px solid rgba(255,255,255,0.08)'}}>
        <button onClick={logout} style={{width:'100%',display:'flex',alignItems:'center',gap:10,padding:'10px 12px',borderRadius:10,background:'rgba(229,62,62,0.15)',color:'#FC8181',fontFamily:'Nunito,sans-serif',fontWeight:600,fontSize:'0.85rem',border:'none',cursor:'pointer'}}>
          ⬅️ Déconnexion
        </button>
        <div style={{textAlign:'center',marginTop:10,color:'rgba(255,255,255,0.2)',fontSize:'0.65rem',fontFamily:'Nunito,sans-serif'}}>EduPN v1.0 © 2025</div>
      </div>
    </nav>
  )
}import React, { useState } from 'react'
import { useApp } from '../App.jsx'

const pageNames = {
  dashboard:'Tableau de bord', ecoles:'Écoles', eleves:'Élèves',
  professeurs:'Professeurs', notes:'Notes & Bulletins',
  emploi:'Emploi du temps', examens:'Examens & Concours', parents:'Espace Parents'
}

export default function Topbar() {
  const { page, currentUser, setSidebarOpen } = useApp()
  const [search, setSearch] = useState('')

  return (
    <div id="topbar">
      <div style={{display:'flex', alignItems:'center', gap:16}}>
        <button onClick={() => setSidebarOpen(o=>!o)} style={{background:'none',border:'none',cursor:'pointer',padding:4,display:'flex',flexDirection:'column',gap:5}}>
          {[0,1,2].map(i=><div key={i} style={{width:22,height:2,background:'#4A5568',borderRadius:2}}/>)}
        </button>
        <div>
          <h2 style={{fontSize:'1.1rem',fontFamily:'Nunito,sans-serif',fontWeight:800,color:'#1B3A6B',margin:0}}>{pageNames[page]||'EduPN'}</h2>
          <div style={{fontSize:'0.7rem',color:'#718096',fontFamily:'Nunito,sans-serif'}}>Année scolaire 2024–2025</div>
        </div>
      </div>
      <div style={{display:'flex', alignItems:'center', gap:12}}>
        <div style={{position:'relative',display:'flex',alignItems:'center'}}>
          <span style={{position:'absolute',left:10,color:'#A0AEC0',fontSize:'0.85rem'}}>🔍</span>
          <input value={search} onChange={e=>setSearch(e.target.value)} placeholder="Rechercher..." className="input"
            style={{paddingLeft:30,width:200,padding:'7px 12px 7px 30px',fontSize:'0.82rem'}} />
        </div>
        <div style={{width:36,height:36,borderRadius:'50%',background:'linear-gradient(135deg,#2DBE8C,#1B8C65)',display:'flex',alignItems:'center',justifyContent:'center',color:'white',fontWeight:800,fontFamily:'Nunito,sans-serif',fontSize:'0.85rem',flexShrink:0}}>
          {currentUser ? (currentUser.prenom[0]+currentUser.nom[0]).toUpperCase() : 'U'}
        </div>
      </div>
    </div>
  )
}import React from 'react'
