          <div style={{display:'inline-flex',alignItems:'center',gap:8,background:'rgba(45,190,140,0.2)',borderRadius:100,padding:'6px 16px',marginBottom:24,border:'1px solid rgba(45,190,140,0.4)'}}>
            <span style={{color:'#2DBE8C',fontFamily:'Nunito,sans-serif',fontWeight:700,fontSize:'0.85rem'}}>🇳🇪 Ministère de l'Éducation Nationale — Niger</span>
